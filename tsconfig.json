{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "resolveJsonModule": true
  },
  "include": [
    "scripts/**/*.ts",
    "src/skills/_shared/scripts/**/*.ts",
    "src/skills/*/scripts/**/*.ts",
    "tests/**/*.ts",
    "vitest.config.ts"
  ]
}
